# Server
PORT=8765
BASE_URL=https://tuchuang.allapple.top
SHORT_BASE_URL=https://tc.allapple.top

# Admin
# Generate a strong value, for example:
# openssl rand -hex 32
ADMIN_TOKEN=change-me
# TUCHUANG_ADMIN_TOKEN can also be used by older deployments.
# TUCHUANG_ADMIN_TOKEN=change-me

# Upload limits
PUBLIC_MAX_FILE_MB=1024
ADMIN_MAX_FILE_MB=10240
MAX_FILES=50

# Runtime paths
UPLOAD_DIR=./uploads
QUARANTINE_DIR=./uploads/.quarantine
CHUNK_DIR=./uploads/.chunks
INDEX_FILE=./file-index.json
DB_FILE=./data/tuchuang.sqlite
LOG_DIR=./logs

# Resumable upload
RESUMABLE_CHUNK_SIZE=8388608
CHUNK_SESSION_TTL_MS=86400000
CLEANUP_INTERVAL_MS=3600000

# Local media moderation
MEDIA_MODERATION_ENABLED=true
MEDIA_MODERATION_BLOCK_ON_UNAVAILABLE=false
MEDIA_MODERATION_PYTHON=python3
MEDIA_MODERATION_SCRIPT=./scripts/local-media-moderation.py
MEDIA_MODERATION_MAX_VIDEO_FRAMES=12
MEDIA_MODERATION_VIDEO_FRAME_INTERVAL_SECONDS=5
MEDIA_MODERATION_TIMEOUT_MS=120000
FFMPEG_PATH=ffmpeg
